/*
 * Example: sieve of Eratosthenes
 */

fun sieve(n) {
	var primes : vector<int> = {};
	var candidates : vector<bool> = {};
	for var i = 0; i < n+1; ++i {
		candidates.push_back(true);
	}
	for var i = 2; i < n+1; ++i {
		if !candidates[i] {
			continue;
		} else {
			primes.push_back(i);
		}
		for var j = i * i; j < n+1; j += i {
			candidates[j] = false;
		}
	}
	return primes;
}