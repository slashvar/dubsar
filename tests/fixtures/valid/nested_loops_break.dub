// Nested loops with break and continue.
fun find_pair(n : int) -> int {
    for var i = 0; i < n; ++i {
        for var j = 0; j < n; ++j {
            if (j == i) {
                break;
            }
            if (j == 0) {
                continue;
            }
        }
    }
    return 0;
}

fun outer_break(n : int) {
    var found : int = 0;
    for var i = 0; i < n; ++i {
        if (found == 1) {
            break;
        }
        for var j = 0; j < n; ++j {
            if (i == j) {
                found = 1;
                break;
            }
        }
    }
}
